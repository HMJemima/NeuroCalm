# Leave DATABASE_URL empty to use the POSTGRES_* values below instead.
DATABASE_URL=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=neurocalm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-postgres-password

SECRET_KEY=replace-this-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Leave these empty to run the backend in simulation mode.
MODEL_PATH=model/SALIENT_model.h5
MODEL_TYPE=SALIENT
MODEL_LOAD_MODE=lazy
SCALER_PATH=model/SALIENT_scaler.pkl
MODEL_METADATA_PATH=model/deploy_metadata.json

WINDOW_SIZE=150
WINDOW_STRIDE=3
N_CLASSES=4
FNIRS_FEATURES=AB_I_O,AB_PHI_O,AB_I_DO,AB_PHI_DO,CD_I_O,CD_PHI_O,CD_I_DO,CD_PHI_DO
